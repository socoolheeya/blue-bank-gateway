# Spring Configuration
SPRING_PROFILES_ACTIVE=prod

# JWT Configuration
# Generate a secure secret key with at least 256 bits (32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-secret-key-must-be-at-least-256-bits-long-for-hs256-algorithm

# Redis Configuration
# Leave empty for development (no password)
# Set a strong password for production: openssl rand -base64 32
REDIS_PASSWORD=

# Backend Service URLs
SEARCH_SERVICE_URL=http://search-service:8081
PAYMENT_SERVICE_URL=http://payment-service:8082